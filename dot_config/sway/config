# vi: ft=swayconfig ts=4 sw=4 et
#
# Read `man 5 sway` for a complete reference.

# Set modifier key.
#
# For specifying modifier keys, the following XKB modifier names and
# aliases may be used:
#   - Shift
#   - Lock (for Caps Lock)
#   - Control
#   - Ctrl
#   - Alt
#   - Mod1 (for Alt)
#   - Mod2 (for Num Lock)
#   - Mod3 (for XKB modifier Mod3)
#   - Super (for the Logo key)
#   - Mod4 (for the Logo key)
#   - Mod5 (for AltGr)
set $mod Super

# Home row-ish direction keys, like vim.
set $left h
set $down j
set $up k
set $right l

# Preferred terminal emulator.
set $term alacritty

# Preferred application launcher.
set $menu rofi -show drun

# Preferred screen locker.
set $screenlock swaylock -f

# Preferred screenshot utility.
set $screenshot_output \
    grim -g "$(slurp -o -r)" -t ppm - | satty -f - --fullscreen
set $screenshot_area \
    grim -g "$(slurp -d)" -t ppm - | satty -f - --floating-hack

# Configure output resolution, refresh rate, and position.
# Output names, and their supported modes, can be found by
# running: `swaymsg -t get_outputs`.
output DP-1 mode 2560x1440@143.998Hz pos 0 0
output DP-2 mode 2560x1440@143.998Hz pos 2560 0

# Set wallpaper for all outputs.
output * bg /usr/share/backgrounds/wallhaven-farcry.png fill

# Specifically pin workspaces to outputs.
workspace 1 output DP-1
workspace 2 output DP-2

# Idle configuration:
#
# 1. Lock the displays after 600 seconds (10 minutes) of inactivity or
#    when put to sleep.
# 2. Turn off displays after another 60 seconds of inactivity.
# 3. Turn on displays when resumed.
exec swayidle -w                                \
    before-sleep "$screenlock"                  \
    timeout 600 "$screenlock"                   \
    timeout 660 "swaymsg 'output * power off'"  \
    resume "swaymsg 'output * power on'"

# Disable mouse acceleration.
input "type:pointer" {
    accel_profile flat
    pointer_accel 0.30
}

# Set key repeat rate and delay. Disable Caps Lock.
input "type:keyboard" {
    repeat_rate 50
    repeat_delay 300
    xkb_options caps:none
}

# Start a terminal.
bindsym $mod+Return exec $term

# Start application launcher.
bindsym $mod+d exec $menu

# Kill focused window.
bindsym $mod+Shift+q kill

# Lock the screen.
bindsym $mod+Control+q exec $screenlock

# Take a screenshot of an output.
bindsym Print exec $screenshot_output

# Take a screenshot of a selected area.
bindsym $mod+Shift+s exec $screenshot_area

# Reload sway configuration.
bindsym $mod+Shift+c reload

# Disable borders on tiled windows.
default_border none

# Do not move the mouse when changing focus.
mouse_warping none

# Do not automatically change focus when moving the mouse to another
# container.
focus_follows_mouse no

# Only enable gaps when the workspace has more than one child.
smart_gaps on

# Set gap size around windows.
gaps inner 10

# Set gap size around workspaces.
gaps outer 0

# Drag floating windows by holding down $mod and left mouse button.
# Resize floating windows by holding down $mod and right mouse button.
floating_modifier $mod normal

# Move active focus with vim keys.
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Move active focus with arrow keys.
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move the focused window with vim keys.
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# Move the focused window with arrow keys.
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Switch to workspace N.
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Move focused container to workspace N.
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Split the current focused object horizontally.
bindsym $mod+b splith

# Split the current focused object vertically.
bindsym $mod+v splitv

# Make the current focus fullscreen.
bindsym $mod+f fullscreen

# Toggle the current focus between tiling and floating mode.
bindsym $mod+Shift+space floating toggle

# Swap focus between the tiling area and the floating area.
bindsym $mod+space focus mode_toggle

# Move focus to the parent container.
bindsym $mod+a focus parent

# Define resize mode.
mode "resize" {
    # Resize a container with vim keys.
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    # Resize a container with arrow keys.
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode.
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# Enter resize mode.
bindsym $mod+r mode "resize"

# Adjust volume via PulseAudio.
bindsym --locked XF86AudioMute \
    exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume \
    exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume \
    exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute \
    exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

# Control media via playerctl.
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioPause exec playerctl play-pause
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioStop exec playerctl stop

# Adjust brightness via brightnessctl.
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

# Use waybar.
bar {
    swaybar_command waybar
}

# Ensure that systemd user services and D-Bus know about the session.
exec systemctl --user set-environment XDG_CURRENT_DESKTOP=sway

exec systemctl --user import-environment DISPLAY                            \
                                         SWAYSOCK                           \
                                         WAYLAND_DISPLAY                    \
                                         XDG_CURRENT_DESKTOP

exec hash dbus-update-activation-environment 2>/dev/null &&                 \
     dbus-update-activation-environment --systemd DISPLAY                   \
                                                  SWAYSOCK                  \
                                                  XDG_CURRENT_DESKTOP=sway  \
                                                  WAYLAND_DISPLAY
