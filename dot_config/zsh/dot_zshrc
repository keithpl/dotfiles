# Bootstrap: create required directories, etc.
source "$ZDOTDIR/init.zsh"

# Load environment and local shell variables.
source "$ZDOTDIR/vars.zsh"

# Load shell aliases.
source "$ZDOTDIR/alias.zsh"

# Load zsh options.
source "$ZDOTDIR/setopt.zsh"

# Load zsh keyboard bindings.
source "$ZDOTDIR/keybind.zsh"

# Load my plugin manager, zeal.
source "$ZDOTDIR/zeal.zsh"

# Load plugins to be installed by zeal.
source "$ZDOTDIR/plugins.zsh"

# Load completion configuration.
# Completion needs to be sourced near the end so `fpath` is populated
# before `compinit` is ran.
source "$ZDOTDIR/completion.zsh"

# Launch tmux if not already running within tmux or remotely accessing
# via SSH.
if command -v tmux >/dev/null 2>&1 && [[ -z "$TMUX" ]] &&
	[[ -z "$SSH_CLIENT" ]] && [[ -z "$SSH_TTY" ]]; then

	tmux
fi
