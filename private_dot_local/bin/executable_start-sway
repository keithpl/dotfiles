#!/usr/bin/env bash

export XDG_SESSION_TYPE="wayland"
export XDG_CURRENT_DESKTOP="sway"
export XDG_SESSION_DESKTOP="sway"

export QT_QPA_PLATFORM="wayland"
export QT_QPA_PLATFORMTHEME="qt5ct"
export QT_WAYLAND_DISABLE_WINDOWDECORATION="1"

export LIBVA_DRIVER_NAME="nvidia"
export NVD_BACKEND="direct"
export __GLX_VENDOR_LIBRARY_NAME="nvidia"
export CUDA_CACHE_PATH="$HOME/.cache/nvidia/ComputeCache"

# Don't put the gpu in P0 just because there's a cuda workload.
# Might remove once libva-nvidia-driver is no longer needed.
export CUDA_DISABLE_PERF_BOOST=1

# Required until firefox supports vulkan video decoding (v153)
export MOZ_DISABLE_RDD_SANDBOX=1

exec sway --unsupported-gpu "$@"
